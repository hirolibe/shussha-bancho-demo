# Phase 1 用サンプル環境変数
# このファイルをコピーして .env を作成し、実値を埋めること（.env はコミットしない）
#
# ※ Phase1 ではアプリ初回起動時に Settings 画面でトークンを入力し、
#   expo-secure-store に保管する運用を推奨。.env はあくまで開発時の補助。

# Slack User OAuth Token (xoxp-... )
SLACK_USER_TOKEN=

# 検知対象 iBeacon の UUID / Major / Minor
BEACON_UUID=
BEACON_MAJOR=
BEACON_MINOR=

# 検知判定の RSSI 下限 (dBm)。-75 が目安
RSSI_THRESHOLD=-75
